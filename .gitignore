# ---- Dependencies ----
node_modules/
.pnp
.pnp.js

# ---- Build output ----
dist/
build/
.vite/
*.tsbuildinfo

# ---- Environment / secrets ----
# Never commit real secrets. .env.example templates are intentionally excluded
# too (per project policy) — anything matching .env* stays out of git.
.env
.env.*
*.pem

# ---- Logs ----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Local tooling / editor ----
.claude/
.vscode/
.idea/
*.swp

# ---- OS cruft ----
.DS_Store
Thumbs.db
desktop.ini
